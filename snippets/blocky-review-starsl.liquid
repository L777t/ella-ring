{%- liquid
  assign settings = block.settings
  assign rating = settings.rating | default: 0
  assign star_color = settings.star_color | default: '#ffcc00'
  assign review_text_color = settings.review_text_color | default: '#111111'
  assign review_text = settings.review_text
  assign review_font_size = settings.review_font_size | default: 16
  assign empty_stars_style = settings.empty_stars_style | default: 'hidden'
  assign rating_percent = rating | times: 20
-%}
{%- if rating > 0 -%}
  <div class="product-review-stars-container" style="display: inline-flex; align-items: center; gap: 0.65rem; flex-wrap: wrap;">
    <span class="product-review-stars" style="position: relative; display: inline-block; line-height: 1; font-size: 1.1rem; letter-spacing: 0.08em;">
      <span
        aria-hidden="true"
        style="color: {% if empty_stars_style == 'hidden' %}transparent{% else %}{{ star_color }}33{% endif %};"
      >
        &#9733;&#9733;&#9733;&#9733;&#9733;
      </span>
      <span
        aria-hidden="true"
        style="position: absolute; inset: 0 auto 0 0; overflow: hidden; width: {{ rating_percent }}%; white-space: nowrap; color: {{ star_color }};"
      >
        &#9733;&#9733;&#9733;&#9733;&#9733;
      </span>
      <span class="visually-hidden">{{ rating }} / 5</span>
    </span>
    {%- if review_text != blank -%}
      <span class="blocky-review-stars-text" style="color: {{ review_text_color }}; font-size: {{ review_font_size }}px; line-height: 1.4;">
        {{ review_text }}
      </span>
    {%- endif -%}
  </div>
{%- endif -%}
