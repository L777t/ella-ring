{%- liquid
  assign video_class = 'blocky-video'
  if other_classes != blank
    assign video_class = video_class | append: ' ' | append: other_classes
  endif
  assign autoplay_enabled = autoplay | default: false
  assign button_color_value = button_color | default: '#FFFFFF'
  assign button_background_value = background_button_color | default: '#111111'
  assign video_style = 'width: 100%; height: 100%;'
-%}
<div
  class="{{ video_class }}{% if video_fit == 'zoomed' %} blocky-video-fit-zoomed{% endif %}"
  style="position: relative; width: 100%; height: 100%; line-height: 0; --blocky-video-button-color: {{ button_color_value }}; --blocky-video-button-background: {{ button_background_value }};"
>
  {%- if video != blank -%}
    {% render 'video', video: video, video_autoplay: autoplay_enabled, video_loop: autoplay_enabled, video_class: 'blocky-video-media', video_style: video_style %}
  {%- else -%}
    <div class="bky-vid-placeholder{% if other_classes != blank %} {{ other_classes }}{% endif %}" style="display: grid; place-items: center; min-height: 16rem; border-radius: 12px; background: {{ fill | default: '#e9e9e9' }}; color: {{ button_color_value }};">
      <span
        class="blocky-video-play-button"
        aria-hidden="true"
        style="display: inline-flex; align-items: center; justify-content: center; width: 3.5rem; height: 3.5rem; border-radius: 999px; background: {{ button_background_value }};"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="{{ button_color_value }}" xmlns="http://www.w3.org/2000/svg"><path d="M8 6.82v10.36c0 .79.87 1.27 1.54.84l8.14-5.18a1 1 0 0 0 0-1.69L9.54 5.98A1 1 0 0 0 8 6.82Z"/></svg>
      </span>
    </div>
  {%- endif -%}
</div>
