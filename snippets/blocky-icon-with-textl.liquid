{%- liquid
  assign settings = block.settings
  assign icon_choice = settings.icon_choice | default: 'icon'
  assign icon_position = icon_position | default: 'left'
  assign heading_html = settings.icon_heading | default: settings.heading | default: settings.title
  assign description_html = settings.icon_description | default: settings.description | default: settings.desc | default: settings.text
  assign icon_color = settings.icon_color | default: '#111111'
  assign heading_color = settings.icon_heading_color | default: '#111111'
  assign text_color = settings.icon_text_color | default: '#444444'
-%}
<div
  class="blocky-icon-with-text blocky-icon-with-text-{{ icon_position }} blocky-icon-with-text-side-{{ side | default: 0 }}"
  {% if block.shopify_attributes %}
    {{ block.shopify_attributes }}
  {% endif %}
  style="display: flex; align-items: flex-start; gap: 0.9rem; margin-bottom: 1rem;"
>
  <div class="blocky-icon-with-text__media" style="flex: 0 0 auto; color: {{ icon_color }}; line-height: 1;">
    {%- if settings.icon_image != blank and icon_choice == 'image' -%}
      <img
        src="{{ settings.icon_image | image_url: width: 120 }}"
        alt=""
        loading="lazy"
        width="60"
        style="display: block; width: 60px; height: 60px; object-fit: contain;"
      >
    {%- elsif settings.icon_image != blank and settings.icon_code == blank -%}
      <img
        src="{{ settings.icon_image | image_url: width: 120 }}"
        alt=""
        loading="lazy"
        width="60"
        style="display: block; width: 60px; height: 60px; object-fit: contain;"
      >
    {%- elsif settings.icon_code != blank -%}
      <span class="material-icons material-symbols-outlined blocky-icon" style="font-size: 2rem; color: {{ icon_color }};">{{ settings.icon_code }}</span>
    {%- endif -%}
  </div>
  <div class="blocky-icon-with-text__content" style="flex: 1 1 auto;">
    {%- if heading_html != blank -%}
      <div style="color: {{ heading_color }}; line-height: 1.3; margin-bottom: 0.35rem;">
        {{ heading_html }}
      </div>
    {%- endif -%}
    {%- if description_html != blank -%}
      <div style="color: {{ text_color }}; line-height: 1.55;">
        {{ description_html }}
      </div>
    {%- endif -%}
  </div>
</div>
